{
  "name": "@sourceog/renderer",
  "version": "1.0.0",
  "description": "Alibaba CTO 2027 Standard RSC Renderer — Zero-config, multi-runtime, production-grade Server Components.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./rsc": {
      "import": "./dist/rsc.mjs",
      "require": "./dist/rsc.cjs"
    },
    "./render": {
      "import": "./dist/render.mjs",
      "require": "./dist/render.cjs"
    },
    "./transpiler": {
      "import": "./dist/transpiler/transpiler-core.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/rsc.ts src/render.tsx src/transpiler/transpiler-core.ts --format esm,cjs --dts --out-dir dist --clean",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-server-dom-webpack": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@sourceog/platform": "workspace:*",
    "@sourceog/router": "workspace:*",
    "@sourceog/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "^0.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-server-dom-webpack": "^18.2.0",
    "sucrase": "^3.35.0",
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "volta": {
    "node": "22.6.0"
  }
}