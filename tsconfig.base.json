{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "sourceog": ["packages/sourceog/src/index.ts"],
      "sourceog/actions": ["packages/sourceog/src/actions.ts"],
      "sourceog/auth": ["packages/sourceog/src/auth.ts"],
      "sourceog/automation": ["packages/sourceog/src/automation.ts"],
      "sourceog/cache": ["packages/sourceog/src/cache.ts"],
      "sourceog/client-island": ["packages/sourceog/src/client-island.ts"],
      "sourceog/config": ["packages/sourceog/src/config.ts"],
      "sourceog/doctor": ["packages/sourceog/src/doctor.ts"],
      "sourceog/explain": ["packages/sourceog/src/explain.ts"],
      "sourceog/graph": ["packages/sourceog/src/graph.ts"],
      "sourceog/headers": ["packages/sourceog/src/headers.ts"],
      "sourceog/governance": ["packages/sourceog/src/governance.ts"],
      "sourceog/i18n": ["packages/sourceog/src/i18n.ts"],
      "sourceog/image": ["packages/sourceog/src/image.ts"],
      "sourceog/inspect": ["packages/sourceog/src/inspect.ts"],
      "sourceog/navigation": ["packages/sourceog/src/navigation.ts"],
      "sourceog/platform": ["packages/sourceog/src/platform.ts"],
      "sourceog/policies": ["packages/sourceog/src/policies.ts"],
      "sourceog/request": ["packages/sourceog/src/request.ts"],
      "sourceog/replay": ["packages/sourceog/src/replay.ts"],
      "sourceog/runtime": ["packages/sourceog/src/runtime.ts"],
      "sourceog/server": ["packages/sourceog/src/server.ts"],
      "sourceog/testing": ["packages/sourceog/src/testing.ts"],
      "sourceog/validation": ["packages/sourceog/src/validation.ts"],
      "@sourceog/runtime": ["packages/sourceog-runtime/src/index.ts"],
      "@sourceog/runtime/*": ["packages/sourceog-runtime/src/*"],
      "@sourceog/router": ["packages/sourceog-router/src/index.ts"],
      "@sourceog/renderer": ["packages/sourceog-renderer/src/index.ts"],
      "@sourceog/renderer/*": ["packages/sourceog-renderer/src/*"],
      "@sourceog/compiler": ["packages/sourceog-compiler/src/index.ts"],
      "@sourceog/dev": ["packages/sourceog-dev/src/index.ts"],
      "@sourceog/server": ["packages/sourceog-server/src/index.ts"],
      "@sourceog/server/route": ["packages/sourceog-server/src/route.ts"],
      "@sourceog/platform": ["packages/sourceog-platform/src/index.ts"],
      "@sourceog/platform/*": ["packages/sourceog-platform/src/*"],
      "@sourceog/platform/config": ["packages/sourceog-platform/src/config.ts"],
      "@sourceog/testing": ["packages/sourceog-testing/src/index.ts"],
      "@sourceog/adapter-node": ["packages/adapter-node/src/index.ts"],
      "@sourceog/adapter-cloudflare": ["packages/adapter-cloudflare/src/index.ts"],
      "@sourceog/adapter-vercel-node": ["packages/adapter-vercel-node/src/index.ts"],
      "@sourceog/adapter-vercel-edge": ["packages/adapter-vercel-edge/src/index.ts"],
      "@sourceog/adapter-utils": ["packages/adapter-utils/src/index.ts"],
      "@sourceog/genbook/errors/base": ["packages/genbook/src/errors/base.ts"],
      "@sourceog/genbook/errors/core.errors": ["packages/genbook/src/errors/core.errors.ts"],
      "@sourceog/genbook/errors/render.errors": ["packages/genbook/src/errors/render.errors.ts"],
      "@sourceog/genbook/errors/transpile.errors": ["packages/genbook/src/errors/transpile.errors.ts"],
      "@sourceog/genbook/errors/manifest.errors": ["packages/genbook/src/errors/manifest.errors.ts"],
      "@sourceog/genbook/errors/worker.errors": ["packages/genbook/src/errors/worker.errors.ts"],
      "@sourceog/genbook": ["packages/genbook/src/index.ts"],
      "@sourceog/genbook/errors": ["packages/genbook/src/errors/index.ts"],
      "@sourceog/genbook/policy": ["packages/genbook/src/policy/index.ts"],
      "@sourceog/genbook/graph": ["packages/genbook/src/graph/index.ts"],
      "@sourceog/genbook/optimistic": ["packages/genbook/src/optimistic/index.ts"],
      "@sourceog/genbook/resilience": ["packages/genbook/src/resilience/index.ts"],
      "@sourceog/genbook/observability": ["packages/genbook/src/observability/index.ts"],
      "@sourceog/genbook/types": ["packages/genbook/src/types/index.ts"],
      "@sourceog/genbook/errors/*": ["packages/genbook/src/errors/*"],
      "@genbook": ["packages/genbook/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "examples/**/*.ts", "examples/**/*.tsx", "tests/**/*.ts"]
}
